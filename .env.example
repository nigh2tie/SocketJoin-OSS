# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=socketjoin
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# アプリケーション
APP_ENV=development # 本番環境では production に設定
APP_PORT=8080
WEB_PORT=3000
FRONTEND_URL=http://localhost:3000

# カンマ区切りの追加禁止ワードリスト（例: spam,badword）。未設定でも組み込みデフォルトワードは常に有効
NG_WORDS=
# データ保持期間（日数）。この日数を超えた投票データは毎日自動削除されます（デフォルト: 90）
POLL_RETENTION_DAYS=90

# フロントエンド開発
VITE_API_URL=http://localhost:8080

# テスト
PLAYWRIGHT_BASE_URL=http://localhost:5173